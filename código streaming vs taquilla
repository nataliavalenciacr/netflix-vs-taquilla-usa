extraer <- function(modelo, variable) {
  if (variable %in% rownames(modelo)) {
    coef <- round(modelo[variable, "Estimate"], 4)
    pval <- modelo[variable, "Pr(>|t|)"]
    sig  <- ifelse(pval < 0.001, "***",
             ifelse(pval < 0.01, "**",
              ifelse(pval < 0.05, "*",
               ifelse(pval < 0.10, ".", ""))))
    paste0(coef, sig)
  } else {
    "—"
  }
}

